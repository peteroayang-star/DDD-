@model UpdateTodoItemRequest
@{
    ViewData["Title"] = "编辑待办事项";
    var id = ViewBag.Id;
}

<div id="editApp">
    <el-card>
        <div slot="header">
            <span style="font-size: 18px; font-weight: bold;">编辑待办事项</span>
        </div>

        <el-form :model="form" label-width="100px">
            <el-form-item label="标题" required>
                <el-input v-model="form.title" placeholder="请输入标题"></el-input>
            </el-form-item>

            <el-form-item label="描述">
                <el-input type="textarea" v-model="form.description" 
                          :rows="4" placeholder="请输入描述"></el-input>
            </el-form-item>

            <el-form-item>
                <el-button type="primary" @@click="submitForm">保存</el-button>
                <el-button @@click="goBack">取消</el-button>
            </el-form-item>
        </el-form>
    </el-card>
</div>

<script>
new Vue({
    el: '#editApp',
    data() {
        return {
            form: {
                title: '@Model.Title',
                description: '@Model.Description'
            }
        };
    },
    methods: {
        submitForm() {
            if (!this.form.title) {
                this.$message.error('请输入标题');
                return;
            }
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '@Url.Action("Edit", new { id = id })';
            
            const titleInput = document.createElement('input');
            titleInput.type = 'hidden';
            titleInput.name = 'Title';
            titleInput.value = this.form.title;
            form.appendChild(titleInput);
            
            const descInput = document.createElement('input');
            descInput.type = 'hidden';
            descInput.name = 'Description';
            descInput.value = this.form.description || '';
            form.appendChild(descInput);
            
            document.body.appendChild(form);
            form.submit();
        },
        goBack() {
            location.href = '@Url.Action("Index")';
        }
    }
});
</script>
