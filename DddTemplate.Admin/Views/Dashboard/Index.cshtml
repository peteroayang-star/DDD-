@model DddTemplate.Admin.Models.DashboardStatistics
@{
    ViewData["Title"] = "仪表盘";
}

<!-- 仪表盘页面 -->
<div>
    <el-row :gutter="20">
        <el-col :span="6">
            <el-card shadow="hover">
                <div style="display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <div style="color: #909399; font-size: 14px;">总用户数</div>
                        <div style="font-size: 28px; font-weight: bold; margin-top: 10px;">@Model.TotalUsers</div>
                    </div>
                    <i class="el-icon-user" style="font-size: 48px; color: #409EFF;"></i>
                </div>
            </el-card>
        </el-col>
        
        <el-col :span="6">
            <el-card shadow="hover">
                <div style="display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <div style="color: #909399; font-size: 14px;">待办事项</div>
                        <div style="font-size: 28px; font-weight: bold; margin-top: 10px;">@Model.TotalTodoItems</div>
                        <div style="color: #67C23A; font-size: 12px; margin-top: 5px;">已完成: @Model.CompletedTodoItems</div>
                    </div>
                    <i class="el-icon-tickets" style="font-size: 48px; color: #67C23A;"></i>
                </div>
            </el-card>
        </el-col>
        
        <el-col :span="6">
            <el-card shadow="hover">
                <div style="display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <div style="color: #909399; font-size: 14px;">今日访问</div>
                        <div style="font-size: 28px; font-weight: bold; margin-top: 10px;">@Model.TodayVisits</div>
                    </div>
                    <i class="el-icon-view" style="font-size: 48px; color: #E6A23C;"></i>
                </div>
            </el-card>
        </el-col>
        
        <el-col :span="6">
            <el-card shadow="hover">
                <div style="display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <div style="color: #909399; font-size: 14px;">系统消息</div>
                        <div style="font-size: 28px; font-weight: bold; margin-top: 10px;">@Model.SystemMessages</div>
                    </div>
                    <i class="el-icon-message" style="font-size: 48px; color: #F56C6C;"></i>
                </div>
            </el-card>
        </el-col>
    </el-row>
    
    <el-row :gutter="20" style="margin-top: 20px;">
        <el-col :span="12">
            <el-card>
                <div slot="header">
                    <span style="font-weight: bold;">快速操作</span>
                </div>
                <!-- 快速操作按钮 -->
                <el-button type="primary" icon="el-icon-plus" onclick="window.location.href='/TodoItem/Create'">新增待办</el-button>
                <el-button type="success" icon="el-icon-tickets" onclick="window.location.href='/TodoItem'">待办列表</el-button>
                <el-button type="info" icon="el-icon-refresh" onclick="location.reload()">刷新数据</el-button>
            </el-card>
        </el-col>
        
        <el-col :span="12">
            <el-card>
                <div slot="header">
                    <span style="font-weight: bold;">系统信息</span>
                </div>
                <div style="line-height: 2;">
                    <div><strong>系统版本：</strong>DDD Template v1.0.0</div>
                    <div><strong>框架版本：</strong>.NET 9.0</div>
                    <div><strong>待办总数：</strong>@Model.TotalTodoItems 项</div>
                    <div><strong>未完成：</strong>@Model.PendingTodoItems 项</div>
                </div>
            </el-card>
        </el-col>
    </el-row>
</div>
