@model List<OperationLogDto>
@{
    ViewData["Title"] = "操作日志";
}

<!-- 操作日志列表页面 -->
<div>
    <el-card>
        <!-- 卡片头部 -->
        <div slot="header" style="display: flex; justify-content: space-between; align-items: center;">
            <div style="display: flex; align-items: center; gap: 15px;">
                <el-button size="small" icon="el-icon-back" @@click="navigate('/Dashboard')">返回</el-button>
                <span style="font-size: 18px; font-weight: bold;">操作日志</span>
            </div>
            <div style="display: flex; gap: 10px; align-items: center;">
                <el-input v-model="searchText" placeholder="搜索用户名、模块或描述"
                          size="small" style="width: 300px;" clearable>
                    <i slot="prefix" class="el-icon-search" style="line-height: 32px;"></i>
                </el-input>
                <el-button size="small" icon="el-icon-refresh" @@click="refreshData">刷新</el-button>
            </div>
        </div>

        <!-- 筛选条件 -->
        <div style="margin-bottom: 15px; display: flex; gap: 10px; flex-wrap: wrap;">
            <el-select v-model="filterModule" placeholder="筛选模块" size="small" clearable style="width: 150px;">
                <el-option label="全部模块" value=""></el-option>
                <el-option label="待办事项" value="TodoItem"></el-option>
                <el-option label="用户管理" value="User"></el-option>
                <el-option label="系统管理" value="System"></el-option>
            </el-select>

            <el-select v-model="filterOperationType" placeholder="筛选操作类型" size="small" clearable style="width: 150px;">
                <el-option label="全部类型" value=""></el-option>
                <el-option label="创建" value="Create"></el-option>
                <el-option label="更新" value="Update"></el-option>
                <el-option label="删除" value="Delete"></el-option>
                <el-option label="查询" value="Query"></el-option>
            </el-select>

            <el-select v-model="filterStatus" placeholder="筛选状态" size="small" clearable style="width: 150px;">
                <el-option label="全部状态" value=""></el-option>
                <el-option label="成功" value="success"></el-option>
                <el-option label="失败" value="failed"></el-option>
            </el-select>
        </div>

        <!-- 操作日志表格 -->
        <el-table :data="filteredLogs" stripe style="width: 100%" max-height="600">
            <el-table-column label="用户" width="120" prop="userName"></el-table-column>
            <el-table-column label="模块" width="120" prop="module"></el-table-column>
            <el-table-column label="操作类型" width="100">
                <template slot-scope="scope">
                    <el-tag :type="getOperationTypeColor(scope.row.operationType)" size="small">
                        {{ scope.row.operationType }}
                    </el-tag>
                </template>
            </el-table-column>
            <el-table-column label="描述" show-overflow-tooltip>
                <template slot-scope="scope">
                    {{ scope.row.description }}
                </template>
            </el-table-column>
            <el-table-column label="IP地址" width="140" prop="ipAddress"></el-table-column>
            <el-table-column label="状态" width="80">
                <template slot-scope="scope">
                    <el-tag :type="scope.row.isSuccess ? 'success' : 'danger'" size="small">
                        {{ scope.row.isSuccess ? '成功' : '失败' }}
                    </el-tag>
                </template>
            </el-table-column>
            <el-table-column label="耗时" width="100">
                <template slot-scope="scope">
                    {{ scope.row.executionTime }} ms
                </template>
            </el-table-column>
            <el-table-column label="操作时间" width="180">
                <template slot-scope="scope">
                    {{ formatDate(scope.row.operatedAt) }}
                </template>
            </el-table-column>
            <el-table-column label="操作" width="100" fixed="right">
                <template slot-scope="scope">
                    <el-button size="mini" type="primary" @@click="viewDetails(scope.row.id)">
                        <i class="el-icon-view"></i> 详情
                    </el-button>
                </template>
            </el-table-column>
        </el-table>
    </el-card>
</div>

@section Scripts {
<script type="text/javascript">
// 直接在页面加载后设置数据
(function() {
    var modelData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initData);
    } else {
        initData();
    }

    function initData() {
        Vue.nextTick(function() {
            var appElement = document.querySelector('#app');
            if (appElement && appElement.__vue__) {
                var app = appElement.__vue__;

                // 转换数据
                var logs = (modelData || []).map(function(item) {
                    return {
                        id: item.id || item.Id,
                        userName: item.userName || item.UserName,
                        module: item.module || item.Module,
                        operationType: item.operationType || item.OperationType,
                        description: item.description || item.Description,
                        requestPath: item.requestPath || item.RequestPath,
                        requestMethod: item.requestMethod || item.RequestMethod,
                        requestParams: item.requestParams || item.RequestParams,
                        ipAddress: item.ipAddress || item.IpAddress,
                        isSuccess: item.isSuccess !== undefined ? item.isSuccess : item.IsSuccess,
                        errorMessage: item.errorMessage || item.ErrorMessage,
                        operatedAt: item.operatedAt || item.OperatedAt,
                        executionTime: item.executionTime !== undefined ? item.executionTime : item.ExecutionTime
                    };
                });

                app.logs = logs;
                app.searchText = '';
                app.filterModule = '';
                app.filterOperationType = '';
                app.filterStatus = '';
            }
        });
    }
})();
</script>
}
