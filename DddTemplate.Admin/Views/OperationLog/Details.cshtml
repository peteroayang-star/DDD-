@model OperationLogDto
@{
    ViewData["Title"] = "操作日志详情";
}

<!-- 操作日志详情页面 -->
<div>
    <el-card>
        <!-- 卡片头部 -->
        <div slot="header" style="display: flex; justify-content: space-between; align-items: center;">
            <div style="display: flex; align-items: center; gap: 15px;">
                <el-button size="small" icon="el-icon-back" @@click="navigate('/OperationLog')">返回列表</el-button>
                <span style="font-size: 18px; font-weight: bold;">操作日志详情</span>
            </div>
        </div>

        <!-- 详情内容 -->
        <el-descriptions :column="2" border>
            <el-descriptions-item label="日志ID">
                <span style="font-family: monospace;">@Model.Id</span>
            </el-descriptions-item>
            <el-descriptions-item label="操作用户">
                <el-tag size="small">@Model.UserName</el-tag>
            </el-descriptions-item>
            <el-descriptions-item label="操作模块">
                <el-tag type="info" size="small">@Model.Module</el-tag>
            </el-descriptions-item>
            <el-descriptions-item label="操作类型">
                <el-tag type="@GetOperationTypeColor(Model.OperationType)" size="small">@Model.OperationType</el-tag>
            </el-descriptions-item>
            <el-descriptions-item label="操作状态">
                <el-tag type="@(Model.IsSuccess ? "success" : "danger")" size="small">
                    @(Model.IsSuccess ? "成功" : "失败")
                </el-tag>
            </el-descriptions-item>
            <el-descriptions-item label="执行耗时">
                <span>@Model.ExecutionTime ms</span>
            </el-descriptions-item>
            <el-descriptions-item label="IP地址">
                <span>@(Model.IpAddress ?? "-")</span>
            </el-descriptions-item>
            <el-descriptions-item label="操作时间">
                <span>@Model.OperatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
            </el-descriptions-item>
            <el-descriptions-item label="请求路径" :span="2">
                <span style="font-family: monospace;">@(Model.RequestPath ?? "-")</span>
            </el-descriptions-item>
            <el-descriptions-item label="请求方法">
                <el-tag size="small" type="warning">@(Model.RequestMethod ?? "-")</el-tag>
            </el-descriptions-item>
            <el-descriptions-item label="操作描述" :span="2">
                <span>@Model.Description</span>
            </el-descriptions-item>
            @if (!string.IsNullOrEmpty(Model.RequestParams))
            {
                <el-descriptions-item label="请求参数" :span="2">
                    <pre style="background: #f5f7fa; padding: 10px; border-radius: 4px; max-height: 300px; overflow: auto;">@Model.RequestParams</pre>
                </el-descriptions-item>
            }
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <el-descriptions-item label="错误信息" :span="2">
                    <el-alert type="error" :closable="false">
                        <pre style="margin: 0; white-space: pre-wrap; word-wrap: break-word;">@Model.ErrorMessage</pre>
                    </el-alert>
                </el-descriptions-item>
            }
        </el-descriptions>
    </el-card>
</div>

@functions {
    string GetOperationTypeColor(string operationType)
    {
        return operationType switch
        {
            "Create" => "success",
            "Update" => "primary",
            "Delete" => "danger",
            "Query" => "info",
            _ => "info"
        };
    }
}
